# Synthetic Network Forensics Rules

# Alert on HTTP beacon to known mock domain
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"SYNTHETIC MERCENARY SPYWARE: Beacon to C2 Domain"; flow:established,to_server; content:"POST"; http_method; content:"/update/beacon.php?id="; http_uri; content:"Host: c2.example-spyware.xyz"; http_header; classtype:trojan-activity; sid:1000001; rev:1; metadata:author SpywareAccountabilityFramework, warning SYNTHETIC_ONLY;)

# Alert on TLS fingerprint associated with mock spyware
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"SYNTHETIC MERCENARY SPYWARE: Malicious TLS Fingerprint (JA3)"; flow:established,to_server; tls.ja3.hash; content:"e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"; classtype:trojan-activity; sid:1000002; rev:1; metadata:author SpywareAccountabilityFramework, warning SYNTHETIC_ONLY;)
